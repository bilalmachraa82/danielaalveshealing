{
  "installCommand": "bun install",
  "rewrites": [
    { "source": "/api/clients/:path*", "destination": "/api/clients?__path=:path*" },
    { "source": "/api/sessions/:path*", "destination": "/api/sessions?__path=:path*" },
    { "source": "/api/forms/:path*", "destination": "/api/forms?__path=:path*" },
    { "source": "/api/dashboard/:path*", "destination": "/api/dashboard?__path=:path*" },
    { "source": "/api/cron/:path*", "destination": "/api/cron?__path=:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/post-session", "schedule": "0 20 * * *" },
    { "path": "/api/cron/review-request", "schedule": "0 10 * * *" },
    { "path": "/api/cron/rebooking", "schedule": "0 10 * * 1" },
    { "path": "/api/cron/checkin-24h", "schedule": "0 10 * * *" },
    { "path": "/api/cron/nudge-7d", "schedule": "0 10 * * 3" },
    { "path": "/api/cron/birthday", "schedule": "0 8 * * *" },
    { "path": "/api/cron/feedback-request", "schedule": "0 10 * * *" }
  ]
}
